<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.sampahku">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SampahKu">
        <activity
            android:name=".StatistikActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" />
        <activity
            android:name=".RewardActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" />
        <activity
            android:name=".QrActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" /> <!-- SplashScreen = halaman pertama yang ada, muncul 3 detik -->
        <activity
            android:name=".SplashScreen"
            android:exported="true"
            android:theme="@style/Theme.SampahKu.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- LoginActivity = hlm yang muncul setelah splash splashscreen -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" /> <!-- MainActivity = halaman utama yang muncul sehabis halaman login -->
        <activity
            android:name=".ProfilActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" />
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.SampahKu.Splash" />
    </application>

</manifest>