<?xml version="1.0" encoding="utf-8"?>
<!-- card warna putih utk item hadiah/reward -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- nama hadiahnya -->
    <TextView
        android:id="@+id/tv_reward_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gopay Coins Rp 10.000"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans_bold" />

    <!-- deskripsinya -->
    <TextView
        android:id="@+id/tv_reward_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Tukarkan Voucher di Aplikasi Gopay"
        android:textColor="@color/gray_text"
        android:textSize="11sp"
        android:fontFamily="@font/plus_jakarta_sans_regular" />

    <!-- poin diperlukan brp -->
    <TextView
        android:id="@+id/tv_reward_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="100 Poin"
        android:textColor="@color/green_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans_bold" />

    <!-- logo merchant dan tombol utk menukar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <!-- logo merchant -->
        <ImageView
            android:id="@+id/iv_reward_logo"
            android:layout_width="80dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/logo_gopay"
            android:scaleType="fitStart"
            android:contentDescription="Logo merchant" />

        <!-- tombol utk menukar -->
        <TextView
            android:id="@+id/btn_tukar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_pill_green_light"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Tukar"
            android:textColor="@color/green_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/plus_jakarta_sans_bold" />
    </RelativeLayout>
</LinearLayout>