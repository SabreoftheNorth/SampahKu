<?xml version="1.0" encoding="utf-8"?>
<!-- navbar menggunakan relative & layout-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:elevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- tombol home -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Home"
                android:textColor="@color/green_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans_semibold" />

        </LinearLayout>

        <!-- reward -->
        <LinearLayout
            android:id="@+id/nav_reward"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_gift"
                android:contentDescription="Reward" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Reward"
                android:textColor="@color/gray_text"
                android:textSize="10sp"
                android:fontFamily="@font/plus_jakarta_sans_regular" />

        </LinearLayout>

        <!-- QR code di tengah, tapi masalahnya kalau pakai tulisan ya jadi susah gitu -->
        <!-- AAAAAAAAAARGHHH -->
        <LinearLayout
            android:id="@+id/nav_qr"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <!-- tombol QR menonjol di tengah -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="-10dp"
                android:background="@drawable/bg_circle_green">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:contentDescription="QR Code"
                    android:src="@drawable/ic_qr_code" />

            </FrameLayout>

            <!-- me dont know what to do so me comment -->
            <!--
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="QR Code"
                android:textColor="@color/gray_text"
                android:textSize="10sp"
                android:fontFamily="@font/plus_jakarta_sans_regular" />
                -->

        </LinearLayout>

        <!-- STATISTIK-eh -->
        <LinearLayout
            android:id="@+id/nav_statistik"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chart"
                android:contentDescription="Statistik" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Statistik"
                android:textColor="@color/gray_text"
                android:textSize="10sp"
                android:fontFamily="@font/plus_jakarta_sans_regular" />

        </LinearLayout>

        <!-- PROFIL-eh -->
        <LinearLayout
            android:id="@+id/nav_profil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_user"
                android:contentDescription="Profil" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Profil"
                android:textColor="@color/gray_text"
                android:textSize="10sp"
                android:fontFamily="@font/plus_jakarta_sans_regular" />

        </LinearLayout>
    </LinearLayout>
</RelativeLayout>