<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!--main contennya dalam bentuk scrollView-->
    <ScrollView
        android:id="@+id/scroll_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_nav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Header "Halo, Rakha" dan motif-motif lainnya-->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_greeting"
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/plus_jakarta_sans_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_subgreeting"
                        android:textColor="@color/gray_text"
                        android:textSize="13sp"
                        android:fontFamily="@font/plus_jakarta_sans_regular" />
                </LinearLayout>

                <!-- //ikon notifikasi dan profil-->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iv_notif"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_bell"
                        android:padding="6dp"
                        android:contentDescription="Notifikasi" />

                    <ImageView
                        android:id="@+id/iv_profile"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_circle_gray"
                        android:src="@drawable/ic_user"
                        android:padding="8dp"
                        android:contentDescription="Profil"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>
            </RelativeLayout>

            <!--card utk menunjukkan total poin yang sekarang dimiliki -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_points"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="5000 Poin"
                    android:textColor="#FFEB3B"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <!-- tombol yg muncul utk menukar poin -->
                <LinearLayout
                    android:id="@+id/btn_tukar_poin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_pill_dark"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tukar_poin"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:fontFamily="@font/plus_jakarta_sans_semibold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_arrow_right_circle"
                        android:contentDescription="@string/tukar_poin" />

                </LinearLayout>
            </LinearLayout>

            <!-- card utk "Aktivitas Baru"-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aktivitas_terbaru"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <!-- Kain/Cacahan -->
                <include
                    layout="@layout/item_aktivitas"
                    android:id="@+id/item_kain" />

                <!--Botol Plastik -->
                <include
                    layout="@layout/item_aktivitas"
                    android:id="@+id/item_botol" />

                <!-- Kertas Koran -->
                <include
                    layout="@layout/item_aktivitas"
                    android:id="@+id/item_kertas" />
            </LinearLayout>

            <!-- Card untuk fitur edukasi ttg daur ulang -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/edukasi_daur_ulang"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <!-- Item Edukasi 1 -->
                <include
                    layout="@layout/item_edukasi"
                    android:id="@+id/item_edukasi_1" />

                <!-- Item Edukasi 2 -->
                <include
                    layout="@layout/item_edukasi"
                    android:id="@+id/item_edukasi_2" />

                <!-- Item Edukasi 3 -->
                <include
                    layout="@layout/item_edukasi"
                    android:id="@+id/item_edukasi_3" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- navbar -->
    <include
        layout="@layout/bottom_navigation"
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />
</RelativeLayout>