<?xml version="1.0" encoding="utf-8"?>
<!-- item card putih untuk aktivitas terbaru -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- baris atas berisikan: Nama sampah + berat + poin -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_nama_sampah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kain/Cacahan"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans_bold" />

            <TextView
                android:id="@+id/tv_berat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill_green_light"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="0.7 kg"
                android:textColor="@color/green_dark"
                android:textSize="11sp"
                android:fontFamily="@font/plus_jakarta_sans_semibold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_poin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="+140 poin"
            android:textColor="@color/green_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans_bold" />

    </RelativeLayout>

    <!-- tanggal dan lokasinya -->
    <TextView
        android:id="@+id/tv_tanggal_lokasi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="15 April 2026 • Mesin D - Perumahan"
        android:textColor="@color/gray_text"
        android:textSize="11sp"
        android:fontFamily="@font/plus_jakarta_sans_regular" />

</LinearLayout>