<?xml version="1.0" encoding="utf-8"?>
<!-- item card putih utk edukasi -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tv_judul_edukasi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cara Memilah Sampah Plastik"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="@font/plus_jakarta_sans_bold" />

    <TextView
        android:id="@+id/tv_desc_edukasi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Pisahkan sesuai jenis agar poin maksimal"
        android:textColor="@color/gray_text"
        android:textSize="11sp"
        android:fontFamily="@font/plus_jakarta_sans_regular" />

    <!-- tonton video via link -->
    <LinearLayout
        android:id="@+id/btn_tonton_video"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tonton_video"
            android:textColor="@color/green_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans_bold" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_play_circle"
            android:contentDescription="@string/tonton_video" />

    </LinearLayout>

</LinearLayout>