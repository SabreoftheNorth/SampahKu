<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- konten utama dalam bentuk ScrollView (LETSGOO) -->
    <ScrollView
        android:id="@+id/scroll_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_nav"
        android:clipToPadding="false"
        android:paddingBottom="64dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <!-- header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_back_green"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Kembali" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/statistik_title"
                    android:textColor="@color/green_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

            </LinearLayout>

            <!-- total poin-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_points"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="5000 Poin"
                    android:textColor="#FFEB3B"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <!-- tombol tukarkan poin -->
                <LinearLayout
                    android:id="@+id/btn_tukar_poin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_pill_dark"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tukar_poin"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:fontFamily="@font/plus_jakarta_sans_semibold" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_arrow_right_circle"
                        android:contentDescription="@string/tukar_poin" />

                </LinearLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_chart"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:src="@drawable/img_chart_pie"
                android:scaleType="fitCenter"
                android:contentDescription="Chart statistik sampah" />

            <!-- legenda untuk warna chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_legend_title"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <!-- baris 1: botol Plastik dan kain -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <!-- bp: British Petrole- eh sori Botol Plastik -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/bg_legend_circle"
                            android:backgroundTint="#42A5F5" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Botol Plastik"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans_regular" />

                    </LinearLayout>

                    <!-- kain -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/bg_legend_circle"
                            android:backgroundTint="#1565C0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Kain"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans_regular" />

                    </LinearLayout>
                </LinearLayout>

                <!-- baris 2: kertas dan kaleng soda -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <!-- paper without the clip (kertas)-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/bg_legend_circle"
                            android:backgroundTint="#FFEB3B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Kertas"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans_regular" />

                    </LinearLayout>

                    <!-- my little soda can (soda)-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/bg_legend_circle"
                            android:backgroundTint="#FF7043" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Kaleng Soda"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans_regular" />

                    </LinearLayout>
                </LinearLayout>

                <!-- baris 3: minyak bekas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/bg_legend_circle"
                            android:backgroundTint="#E53935" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Minyak Bekas"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/plus_jakarta_sans_regular" />

                    </LinearLayout>

                    <!-- placeholder kosong agar layout tetap simetris -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal" />
                </LinearLayout>
            </LinearLayout>

            <!-- "JENIS SAMPAH TERBANYAK" card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/statistik_most_deposit"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="@font/plus_jakarta_sans_regular" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Botol Plastik"
                    android:textColor="#FFEB3B"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/statistik_total_deposit"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="@font/plus_jakarta_sans_regular" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="5 kg = 1000 Poin"
                    android:textColor="#FFEB3B"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

            </LinearLayout>

            <!-- aktivitas terbaru -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_green"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aktivitas_terbaru"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <include
                    layout="@layout/item_aktivitas"
                    android:id="@+id/item_stat_kain" />

                <include
                    layout="@layout/item_aktivitas"
                    android:id="@+id/item_stat_botol" />

                <include
                    layout="@layout/item_aktivitas"
                    android:id="@+id/item_stat_kertas" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- utk navbarnya -->
    <include
        layout="@layout/bottom_navigation"
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>